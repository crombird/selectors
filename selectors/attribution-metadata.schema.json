{
  "type": "object",
  "properties": {
    "$schema": { "type": "string" }
  },
  "patternProperties": {
    "^http://[a-z-]+\\.wikidot\\.com/[a-z0-9:-]+$": {
      "type": "object",
      "properties": {
        "rowSelector": { "type": "string" },
        "dateFormat": { "type": "string" },
        "types": {
          "type": "object",
          "additionalProperties": {
            "type": "string",
            "enum": ["AUTHOR", "REWRITE", "TRANSLATOR", "MAINTAINER"]
          }
        }
      },
      "required": ["dateFormat", "rowSelector", "types"]
    }
  },
  "additionalProperties": false
}
